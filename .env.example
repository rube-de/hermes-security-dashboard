# Path to the SQLite database file. Created and seeded with demo data on first
# boot. Use an absolute path in production so it's independent of the cwd.
HERMES_DB=hermes.db

# Port for the production server (adapter-node). Default: 3000
# PORT=3000

# Optional Bearer-token auth for the agent-facing WRITE endpoints
# (POST /api/repos, POST /api/repos/:id/reviews, PUT /api/scan).
# Leave UNSET to allow unauthenticated writes (fine for a private/localhost-only
# server). Set it to require:  Authorization: Bearer <token>  on every write.
# HERMES_API_TOKEN=replace-with-a-long-random-secret
