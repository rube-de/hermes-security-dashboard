# Path to the SQLite database file. Created and seeded with demo data on first
# boot. Use an absolute path in production so it's independent of the cwd.
HERMES_DB=hermes.db

# Port for the production server (adapter-node). Default: 3000
# PORT=3000

# Consistent snapshot the durability layer emits for an external sync sidecar to
# copy (VACUUM INTO + atomic rename). The sidecar must sync THIS file, never the
# live .db/-wal/-shm. Default: ${HERMES_DB}.snapshot
# HERMES_DB_SNAPSHOT=/data/hermes.db.snapshot

# Seconds between snapshot+WAL-checkpoint cycles (production server only).
# Default: 300
# HERMES_SNAPSHOT_INTERVAL=300

# Demo seeding on an empty DB. On by default; set false in production so the
# dashboard starts empty until the agent pushes real findings.
# HERMES_SEED_DEMO=false

# Optional Bearer-token auth for the agent-facing WRITE endpoints
# (POST /api/repos, POST /api/repos/:id/reviews, PUT /api/scan).
# Leave UNSET to allow unauthenticated writes (fine for a private/localhost-only
# server). Set it to require:  Authorization: Bearer <token>  on every write.
# HERMES_API_TOKEN=replace-with-a-long-random-secret
